<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShoeStore</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ShoeStore.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
        var isAdmin = User?.IsInRole("Admin") ?? false;
        var isStaff = User?.IsInRole("Staff") ?? false;
    }
    <header>
        <nav class="navbar navbar-expand-lg main-navbar shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand brand-mark" asp-area="" asp-controller="Home" asp-action="Index">ShoeStore</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-flex justify-content-end">
                    <ul class="navbar-nav align-items-lg-center gap-lg-3">
                        @if (isAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-contrast" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-contrast" asp-area="" asp-controller="Product" asp-action="Index">Search</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-contrast" asp-area="" asp-controller="Cart" asp-action="Index">Cart</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-contrast" asp-area="" asp-controller="Order" asp-action="Index">History</a>
                            </li>
                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-link-contrast" asp-area="" asp-controller="Admin" asp-action="Index">Admin</a>
                                </li>
                            }
                            @if (isStaff)
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-link-contrast" asp-area="" asp-controller="Staff" asp-action="Index">Staff</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link nav-link-contrast profile-pill" asp-area="" asp-controller="Account" asp-action="Profile">Profile</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-contrast" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="page-shell">
        <main role="main" class="main-content pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ShoeStore - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
