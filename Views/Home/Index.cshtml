<section class="home-hero">
    <h1>Welcome to Shoes Store</h1>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <p>Hello, @User.Identity!.Name! Enjoy the latest drops tailored for you.</p>
    }
    else
    {
        <p>Discover curated sneakers, sport shoes, and everyday essentials.</p>
    }
</section>

<section class="product-section" data-grid-collapse="4">
    <div class="section-header">
        <h2 class="section-heading">Top Sales</h2>
    </div>
    <div class="product-rail">
        <div class="product-grid" data-product-grid>
            @foreach (var item in topSales)
            {
                <article class="product-card"
                         role="button"
                         tabindex="0"
                         data-product-category="Top Sales"
                         data-product-sku="@item.Sku"
                         data-product-name="@item.Name"
                         data-product-color="@item.Color"
                         data-product-stock="@item.Stock"
                         data-product-price="@item.Price"
                         data-product-sale="@(item.SalePrice?.ToString() ?? string.Empty)"
                         data-product-image="@item.Image"
                         data-product-sizes="@string.Join("|", item.Sizes)">
                    <div class="product-illustration">Shoe</div>
                    <h3>@item.Name</h3>
                    <p class="product-meta">@item.Color</p>
                    @if (item.SalePrice.HasValue)
                    {
                        <div class="price price--sale">
                            <span class="current">@formatPrice(item.SalePrice.Value)</span>
                            <span class="original">@formatPrice(item.Price)</span>
                        </div>
                    }
                    else
                    {
                        <div class="price">@formatPrice(item.Price)</div>
                    }
                </article>
            }
        </div>
        <button type="button" class="grid-arrow" aria-label="ดูสินค้าถัดไป">
            <span>&rsaquo;</span>
        </button>
    </div>
    <button type="button" class="mobile-more-btn">More</button>
</section>

<section class="product-section" data-grid-collapse="4">
    <div class="section-header">
        <h2 class="section-heading">Sport Shoes</h2>
    </div>
    <div class="product-rail">
        <div class="product-grid" data-product-grid>
            @foreach (var item in sportShoes)
            {
                <article class="product-card"
                         role="button"
                         tabindex="0"
                         data-product-category="Sport Shoes"
                         data-product-sku="@item.Sku"
                         data-product-name="@item.Name"
                         data-product-color="@item.Color"
                         data-product-stock="@item.Stock"
                         data-product-price="@item.Price"
                         data-product-sale="@(item.SalePrice?.ToString() ?? string.Empty)"
                         data-product-image="@item.Image"
                         data-product-sizes="@string.Join("|", item.Sizes)">
                    <div class="product-illustration">Run</div>
                    <h3>@item.Name</h3>
                    <p class="product-meta">@item.Color</p>
                    @if (item.SalePrice.HasValue)
                    {
                        <div class="price price--sale">
                            <span class="current">@formatPrice(item.SalePrice.Value)</span>
                            <span class="original">@formatPrice(item.Price)</span>
                        </div>
                    }
                    else
                    {
                        <div class="price">@formatPrice(item.Price)</div>
                    }
                </article>
            }
        </div>
        <button type="button" class="grid-arrow" aria-label="ดูสินค้าถัดไป">
