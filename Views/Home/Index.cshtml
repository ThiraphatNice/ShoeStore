</section>

<div class="product-modal" id="productModal" aria-hidden="true">
    <div class="product-modal__backdrop" data-modal-close></div>
    <div class="product-modal__dialog" role="dialog" aria-modal="true">
        <button type="button" class="modal-close" aria-label="Close" data-modal-close>&times;</button>
        <div class="modal-body">
            <div class="modal-left">
                <div class="modal-image">
                    <img id="modalProductImage" src="" alt="Selected shoe" />
                </div>
                <div class="modal-control">
                    <label for="modalSize">เลือกไซส์</label>
                    <div class="select-wrapper">
                        <select id="modalSize"></select>
                    </div>
                </div>
                <div class="modal-control">
                    <label>จำนวน</label>
                    <div class="qty-control">
                        <button type="button" class="qty-btn" data-qty-action="minus">-</button>
                        <input type="text" id="modalQuantity" value="1" readonly inputmode="numeric" />
                        <button type="button" class="qty-btn" data-qty-action="plus">+</button>
                    </div>
                </div>
            </div>
            <div class="modal-right">
                <h3 id="modalProductName"></h3>
                <ul class="modal-meta">
                    <li><span>รหัสสินค้า:</span> <strong id="modalSku"></strong></li>
                    <li><span>สี:</span> <strong id="modalColor"></strong></li>
                    <li><span>สต็อกคงเหลือ:</span> <strong id="modalStock"></strong></li>
                </ul>
                <div class="modal-price">
                    <span class="modal-price__original" id="modalOriginalPrice"></span>
                    <span class="modal-price__current" id="modalCurrentPrice"></span>
                </div>
                <button type="button" class="btn btn-danger add-to-cart-btn">เพิ่มสินค้าในตะกร้า</button>
            </div>
        </div>
    </div>
</div>
